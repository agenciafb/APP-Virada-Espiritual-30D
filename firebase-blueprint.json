{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "premium"] },
        "streak": { "type": "integer" },
        "progress": { "type": "integer" },
        "last_access": { "type": "string", "format": "date-time" },
        "last_completion_date": { "type": "string", "format": "date" }
      },
      "required": ["id", "email", "name"]
    },
    "Checklist": {
      "title": "Checklist",
      "description": "Daily habit checklist for a user",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "morning_status": { "type": "array", "items": { "type": "string" } },
        "night_status": { "type": "array", "items": { "type": "string" } },
        "mission_status": { "type": "object" }
      },
      "required": ["user_id", "date"]
    },
    "DiaryEntry": {
      "title": "DiaryEntry",
      "description": "Daily journal entry",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "gratitude": { "type": "string" },
        "learning": { "type": "string" }
      },
      "required": ["user_id", "date"]
    },
    "Reflection": {
      "title": "Reflection",
      "description": "User reflection on a specific day's content",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "day_id": { "type": "integer" },
        "content": { "type": "string" }
      },
      "required": ["user_id", "day_id"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Earned achievement for a user",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "achievement_id": { "type": "string" },
        "earned_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "achievement_id", "earned_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/checklists/{date}": {
      "schema": "Checklist",
      "description": "User daily checklists"
    },
    "/users/{userId}/diary/{date}": {
      "schema": "DiaryEntry",
      "description": "User diary entries"
    },
    "/users/{userId}/reflections/{dayId}": {
      "schema": "Reflection",
      "description": "User reflections on daily content"
    },
    "/users/{userId}/achievements/{achievementId}": {
      "schema": "Achievement",
      "description": "User earned achievements"
    }
  }
}
