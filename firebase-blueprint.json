{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "premium"] },
        "streak": { "type": "integer" },
        "progress": { "type": "integer" },
        "last_access": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name"]
    },
    "Day": {
      "title": "Day",
      "description": "Content for each of the 30 days",
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "title": { "type": "string" },
        "verse": { "type": "string" },
        "reflection": { "type": "string" },
        "application": { "type": "string" },
        "exercise": { "type": "string" },
        "declaration": { "type": "string" }
      },
      "required": ["id", "title", "verse", "reflection", "application", "exercise", "declaration"]
    },
    "Prayer": {
      "title": "Prayer",
      "description": "Prayer for crisis mode",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "declaration": { "type": "string" }
      },
      "required": ["category", "title", "content", "declaration"]
    },
    "Declaration": {
      "title": "Declaration",
      "description": "Spiritual declaration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "reference": { "type": "string" }
      },
      "required": ["content", "reference"]
    },
    "Checklist": {
      "title": "Checklist",
      "description": "Daily habits checklist",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "morning_status": { "type": "array", "items": { "type": "string" } },
        "night_status": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["user_id", "date"]
    },
    "Diary": {
      "title": "Diary",
      "description": "Daily diary entry",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "gratitude": { "type": "string" },
        "learning": { "type": "string" }
      },
      "required": ["user_id", "date"]
    },
    "Reflection": {
      "title": "Reflection",
      "description": "User reflection for a specific day",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "day_id": { "type": "integer" },
        "content": { "type": "string" }
      },
      "required": ["user_id", "day_id"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Available achievement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["id", "title", "description", "icon"]
    },
    "UserAchievement": {
      "title": "UserAchievement",
      "description": "Achievement earned by a user",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "achievement_id": { "type": "string" },
        "earned_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "achievement_id", "earned_at"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile and progress"
    },
    "/days/{dayId}": {
      "schema": "Day",
      "description": "Content for each day"
    },
    "/prayers/{prayerId}": {
      "schema": "Prayer",
      "description": "Prayers for crisis mode"
    },
    "/declarations/{declarationId}": {
      "schema": "Declaration",
      "description": "Spiritual declarations"
    },
    "/users/{uid}/checklists/{date}": {
      "schema": "Checklist",
      "description": "User daily habits"
    },
    "/users/{uid}/diary/{date}": {
      "schema": "Diary",
      "description": "User daily diary"
    },
    "/users/{uid}/reflections/{dayId}": {
      "schema": "Reflection",
      "description": "User daily reflections"
    },
    "/achievements/{achievementId}": {
      "schema": "Achievement",
      "description": "Global achievements"
    },
    "/users/{uid}/achievements/{achievementId}": {
      "schema": "UserAchievement",
      "description": "Achievements earned by user"
    }
  }
}
